{
  "manifest_version": 3,
  "name": "Claude Expertise Vault",
  "version": "4.0.0",
  "description": "Search and query the Claude Expertise Vault knowledge base. Semantic vector search, AI-powered Q&A, and content ingestion.",
  "permissions": [
    "activeTab",
    "alarms",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8645/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
